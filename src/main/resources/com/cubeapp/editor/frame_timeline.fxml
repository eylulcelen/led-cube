<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox fx:id="root"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cubeapp.ui.editor.FrameTimelineController"
      spacing="8"
      style="-fx-padding: 10; -fx-background-color: #0a0a18; -fx-min-height: 80;">

    <!-- Add / Remove buttons -->
    <VBox spacing="6" alignment="CENTER">
        <Button text="+" onAction="#onAddFrame"
                prefWidth="32" prefHeight="32"
                style="-fx-font-size: 16px; -fx-background-color: #2ecc71; -fx-text-fill: white;"/>
        <Button text="−" onAction="#onRemoveFrame"
                prefWidth="32" prefHeight="32"
                style="-fx-font-size: 16px; -fx-background-color: #e74c3c; -fx-text-fill: white;"/>
    </VBox>

    <!-- Scrollable frame strip -->
    <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                fitToHeight="true" HBox.hgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <HBox fx:id="frameStrip" spacing="6" alignment="CENTER_LEFT"
              style="-fx-padding: 4;"/>
    </ScrollPane>

    <!-- Move buttons -->
    <VBox spacing="6" alignment="CENTER">
        <Button text="◀" onAction="#onMoveLeft"  prefWidth="32" prefHeight="32"/>
        <Button text="▶" onAction="#onMoveRight" prefWidth="32" prefHeight="32"/>
    </VBox>

</HBox>