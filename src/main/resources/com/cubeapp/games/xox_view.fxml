<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane fx:id="root"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cubeapp.ui.games.XoxController"
            style="-fx-background-color: #0d0d1a;">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="20" style="-fx-padding: 12; -fx-background-color: #13132a; -fx-alignment: center-left;">
            <Label text="XOX ❌⭕"
                   style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Label fx:id="turnLabel"
                   text="Player 1's turn (Blue)"
                   style="-fx-text-fill: #3498db; -fx-font-size: 13px;"/>
            <Label fx:id="statusLabel"
                   text=""
                   style="-fx-text-fill: #e74c3c; -fx-font-size: 13px;"/>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox alignment="CENTER" spacing="20"
              style="-fx-background-color: #0d0d1a; -fx-padding: 30;">

            <!-- Coordinate input -->
            <Label text="Enter move coordinates (0–3 each axis)"
                   style="-fx-text-fill: #aaa; -fx-font-size: 12px;"/>

            <HBox alignment="CENTER" spacing="12">
                <VBox alignment="CENTER" spacing="4">
                    <Label text="X" style="-fx-text-fill: #888;"/>
                    <Spinner fx:id="xSpinner" min="0" max="3" initialValue="0" prefWidth="70"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4">
                    <Label text="Y" style="-fx-text-fill: #888;"/>
                    <Spinner fx:id="ySpinner" min="0" max="3" initialValue="0" prefWidth="70"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4">
                    <Label text="Z" style="-fx-text-fill: #888;"/>
                    <Spinner fx:id="zSpinner" min="0" max="3" initialValue="0" prefWidth="70"/>
                </VBox>
            </HBox>

            <Button text="Place Mark"
                    onAction="#onPlaceMark"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"
                    prefWidth="160" prefHeight="40"/>

            <Separator/>

            <!-- Layer preview — shows a 4x4 grid for selected Z layer -->
            <HBox alignment="CENTER" spacing="16">
                <VBox alignment="CENTER" spacing="6">
                    <Label text="Layer preview (Z)"
                           style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                    <HBox spacing="6">
                        <Label text="Z layer:" style="-fx-text-fill: #888;"/>
                        <Spinner fx:id="previewZSpinner" min="0" max="3" initialValue="0"
                                 prefWidth="70" onValueChange="#onPreviewZChanged"/>
                    </HBox>
                    <GridPane fx:id="layerGrid" hgap="4" vgap="4" alignment="CENTER"/>
                </VBox>
            </HBox>

            <Separator/>

            <Button text="🔄 New Game"
                    onAction="#onNewGame"
                    prefWidth="140" prefHeight="36"/>

        </VBox>
    </center>

</BorderPane>